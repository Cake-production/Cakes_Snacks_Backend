<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="012-create-indexes" author="admin">
        <!-- Additional performance indexes -->
        <createIndex indexName="idx_orders_created_at" tableName="orders">
            <column name="created_at"/>
        </createIndex>
        <createIndex indexName="idx_products_is_active" tableName="products">
            <column name="is_active"/>
        </createIndex>
        <createIndex indexName="idx_products_sales" tableName="products">
            <column name="sales" descending="true"/>
        </createIndex>
        <createIndex indexName="idx_users_role" tableName="users">
            <column name="role"/>
        </createIndex>
        <createIndex indexName="idx_users_created_at" tableName="users">
            <column name="created_at"/>
        </createIndex>
        <createIndex indexName="idx_reviews_rating" tableName="reviews">
            <column name="rating"/>
        </createIndex>
        <createIndex indexName="idx_payments_status" tableName="payments">
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_deliveries_status" tableName="deliveries">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
