<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="010-create-user-profiles-table" author="admin">
        <createTable tableName="user_profiles">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" unique="true" foreignKeyName="fk_user_profiles_user" references="users(id)"/>
            </column>
            <column name="date_of_birth" type="DATE"/>
            <column name="company_name" type="VARCHAR(255)"/>
            <column name="business_type" type="VARCHAR(100)"/>
            <column name="bio" type="LONGTEXT"/>
            <column name="preferred_language" type="VARCHAR(10)" defaultValue="en">
                <constraints nullable="false"/>
            </column>
            <column name="timezone" type="VARCHAR(50)" defaultValue="UTC">
                <constraints nullable="false"/>
            </column>
            <column name="two_factor_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="loyalty_points" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="membership_tier" type="VARCHAR(50)" defaultValue="STANDARD">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex indexName="idx_user_profiles_user_id" tableName="user_profiles">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
